---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const {
  title = 'Siddhant Pathak',
  description = 'Data Scientist at Singapore Airlines — GenAI infrastructure, LLM gateways, RAG, and graph neural network research.',
  wide = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const mainMaxWidth = wide ? 'max-w-4xl' : 'max-w-3xl';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // Theme: respect saved preference, else system. Run in <head> to avoid flash.
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100 transition-colors">
    <Header />
    <main class={`mx-auto ${mainMaxWidth} px-6`}>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // ─── Animations init — re-runs on every view transition navigation ───
      function initAnimations() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        // 1) Scroll-reveal fallback for browsers without scroll-driven animations
        if (!CSS.supports('animation-timeline: view()')) {
          const io = new IntersectionObserver((entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            }
          }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
          document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
        }

        // 2) 3D tilt cards — follow the cursor
        document.querySelectorAll('.tilt-card').forEach((card) => {
          const el = card;
          const onMove = (e) => {
            const rect = el.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width - 0.5;
            const y = (e.clientY - rect.top) / rect.height - 0.5;
            el.style.setProperty('--tilt-x', `${-y * 6}deg`);
            el.style.setProperty('--tilt-y', `${x * 6}deg`);
          };
          const onLeave = () => {
            el.style.setProperty('--tilt-x', `0deg`);
            el.style.setProperty('--tilt-y', `0deg`);
          };
          el.addEventListener('mousemove', onMove);
          el.addEventListener('mouseleave', onLeave);
        });
      }

      // Body scroll sometimes gets stuck if dialog was open during navigation
      function resetBodyScroll() {
        document.body.style.overflow = '';
      }

      initAnimations();
      document.addEventListener('astro:page-load', initAnimations);
      document.addEventListener('astro:before-swap', resetBodyScroll);
    </script>
  </body>
</html>
