---
interface Props {
  title: string;
  lede?: string;
  eyebrow?: string;
}

const { title, lede, eyebrow } = Astro.props;
---

<header class="pt-16 pb-10 sm:pt-24 sm:pb-12">
  {eyebrow && (
    <p class="fade-in text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-3" style="--delay: 60ms">
      {eyebrow}
    </p>
  )}
  <h1 class="fade-in text-4xl sm:text-5xl font-bold tracking-tighter" style="--delay: 140ms">{title}</h1>
  {lede && (
    <p class="fade-in mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl leading-relaxed" style="--delay: 240ms">{lede}</p>
  )}
</header>
