---
import type { Award, Certification } from '../data/achievements';

interface Props {
  heading: string;
  items: Award[] | Certification[];
  variant: 'award' | 'certification';
}

const { heading, items, variant } = Astro.props;

function isAward(item: Award | Certification): item is Award {
  return (item as Award).detail !== undefined;
}
---

<section>
  <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
    {heading}
  </h2>
  <ul class={variant === 'award' ? 'mt-4 space-y-4' : 'mt-4 space-y-3'}>
    {items.map((item) => (
      <li class="rounded-lg border border-slate-200 dark:border-slate-800 p-4">
        {isAward(item) ? (
          <>
            <p class="font-semibold text-sm">{item.title}</p>
            <p class="text-sm text-slate-600 dark:text-slate-300 mt-1">{item.detail}</p>
          </>
        ) : (
          <>
            {item.href ? (
              <a href={item.href} class="font-medium text-sm hover:underline">{item.title}</a>
            ) : (
              <p class="font-medium text-sm">{item.title}</p>
            )}
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">{item.issuer}</p>
          </>
        )}
      </li>
    ))}
  </ul>
</section>
