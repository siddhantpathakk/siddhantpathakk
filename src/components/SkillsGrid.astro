---
import type { SkillGroup } from '../data/skills';
import { accents } from '../lib/accents';

interface Props {
  groups: SkillGroup[];
  columns?: 2 | 3 | 4;
}

const { groups, columns = 4 } = Astro.props;

const colClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
}[columns];
---

<div class={`grid grid-cols-2 gap-4 ${colClass}`}>
  {groups.map((g) => {
    const a = accents[g.accent];
    return (
      <div class="rounded-xl border border-slate-200 dark:border-slate-800 p-4">
        <h3 class:list={['text-sm font-semibold tracking-tight', a.title]}>{g.title}</h3>
        <ul class="mt-3 flex flex-wrap gap-1.5">
          {g.items.map((i) => (
            <li class:list={['rounded-md px-2 py-0.5 text-xs font-medium', a.chip]}>
              {i}
            </li>
          ))}
        </ul>
      </div>
    );
  })}
</div>
