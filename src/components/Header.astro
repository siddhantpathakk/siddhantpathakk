---
import Menu from './Menu.astro';
import ThemeToggle from './ThemeToggle.astro';
import { site } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 bg-white dark:bg-slate-950 border-b border-slate-200/60 dark:border-slate-800/60"
>
  <nav class="mx-auto max-w-4xl px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-sm sm:text-base hover:opacity-80 transition-opacity">
      {site.name}
    </a>
    <div class="flex items-center gap-2">
      <Menu currentPath={currentPath} />
      <ThemeToggle />
    </div>
  </nav>
</header>
