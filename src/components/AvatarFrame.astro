---
interface Props {
  src?: string;
  initials?: string;
  size?: 'sm' | 'md' | 'lg';
  shape?: 'square' | 'circle';
}

const { src, initials = 'SP', size = 'md', shape = 'square' } = Astro.props;

const sizeClass = {
  sm: 'h-24 w-24 text-2xl',
  md: 'h-32 w-32 sm:h-40 sm:w-40 text-3xl',
  lg: 'h-48 w-48 sm:h-64 sm:w-64 text-4xl sm:text-5xl',
}[size];

const shapeClass = shape === 'circle' ? 'rounded-full' : 'rounded-2xl';
---

<div class={`${sizeClass} ${shapeClass} relative overflow-hidden shadow-lg ring-2 ring-indigo-200 dark:ring-indigo-800/60`}>
  <div
    class={`absolute inset-0 bg-indigo-100 dark:bg-indigo-950 flex items-center justify-center font-bold text-indigo-600 dark:text-indigo-400`}
  >
    {initials}
  </div>
  {src && (
    <img
      src={src}
      alt={initials}
      onerror="this.style.display='none'"
      class="relative w-full h-full object-cover"
    />
  )}
</div>
