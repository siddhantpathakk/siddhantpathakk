---
interface Props {
  src?: string;
  initials?: string;
  size?: 'sm' | 'md' | 'lg';
  shape?: 'square' | 'circle';
}

const { src, initials = 'SP', size = 'md', shape = 'square' } = Astro.props;

const sizeClass = {
  sm: 'h-24 w-24 text-2xl',
  md: 'h-32 w-32 sm:h-40 sm:w-40 text-3xl',
  lg: 'h-48 w-48 sm:h-64 sm:w-64 text-4xl sm:text-5xl',
}[size];

const shapeClass = shape === 'circle' ? 'rounded-full' : 'rounded-2xl';
---

<div class={`${sizeClass} ${shapeClass} relative overflow-hidden shadow-lg ring-1 ring-slate-200 dark:ring-slate-800`}>
  <!-- Fallback: gradient + initials, sits behind the img and shows when img errors -->
  <div
    class={`absolute inset-0 bg-gradient-to-br from-slate-200 to-slate-400 dark:from-slate-700 dark:to-slate-900 flex items-center justify-center font-bold text-slate-700 dark:text-slate-200`}
  >
    {initials}
  </div>
  {src && (
    <img
      src={src}
      alt={initials}
      onerror="this.style.display='none'"
      class="relative w-full h-full object-cover"
    />
  )}
</div>
