---
import type { ProjectItem } from '../data/projects';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<a
  href={project.href}
  class="group block rounded-xl border border-slate-200 dark:border-slate-800 p-5 hover:border-slate-400 dark:hover:border-slate-600 hover:bg-slate-50/50 dark:hover:bg-slate-900/40 transition-colors"
>
  <h3 class="font-semibold tracking-tight">{project.title}</h3>
  <div class="mt-2 flex flex-wrap gap-1.5">
    {project.tags.map((tag) => (
      <span class="rounded-md bg-slate-100 dark:bg-slate-800/70 px-2 py-0.5 text-[11px] font-medium text-slate-600 dark:text-slate-300">
        {tag}
      </span>
    ))}
  </div>
  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{project.summary}</p>
</a>
