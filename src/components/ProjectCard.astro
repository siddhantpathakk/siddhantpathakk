---
import type { ProjectItem } from '../data/projects';
import { accents } from '../lib/accents';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
const a = accents[project.accent];
---

<a
  href={project.href}
  class:list={[
    'group block rounded-xl border border-slate-200 dark:border-slate-800 p-5',
    a.hoverBorder,
    a.hoverBg,
  ]}
>
  <h3 class:list={['font-semibold tracking-tight', a.titleHover]}>{project.title}</h3>
  <div class="mt-2 flex flex-wrap gap-1.5">
    {project.tags.map((tag) => (
      <span class:list={['rounded-md px-2 py-0.5 text-[11px] font-medium', a.chip]}>
        {tag}
      </span>
    ))}
  </div>
  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{project.summary}</p>
</a>
