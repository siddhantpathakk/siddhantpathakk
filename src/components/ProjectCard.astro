---
import type { ProjectItem } from '../data/projects';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<a
  href={project.href}
  class="group block rounded-xl border border-slate-200 dark:border-slate-800 p-5 hover:border-indigo-300 dark:hover:border-indigo-700 hover:bg-indigo-50/40 dark:hover:bg-indigo-950/20"
>
  <h3 class="font-semibold tracking-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400">{project.title}</h3>
  <div class="mt-2 flex flex-wrap gap-1.5">
    {project.tags.map((tag) => (
      <span class="rounded-md bg-indigo-50 dark:bg-indigo-950/30 px-2 py-0.5 text-[11px] font-medium text-indigo-700 dark:text-indigo-300">
        {tag}
      </span>
    ))}
  </div>
  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{project.summary}</p>
</a>
