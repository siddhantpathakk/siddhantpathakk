---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- HERO -->
  <section class="pt-20 pb-16 flex flex-col sm:flex-row items-center gap-8">
    <div class="flex-1 text-center sm:text-left">
      <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Hi, I'm</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mt-2">Siddhant Pathak</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        Data Scientist at <span class="text-slate-900 dark:text-white font-medium">Singapore Airlines</span> building
        <span class="text-slate-900 dark:text-white font-medium">GenAI infrastructure</span>, LLM gateways, and
        <span class="text-slate-900 dark:text-white font-medium">RAG systems</span>. NTU Computer Science graduate researching
        <span class="text-slate-900 dark:text-white font-medium">graph neural networks</span> for recommender systems.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 justify-center sm:justify-start">
        <a href="#projects" class="rounded-md bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:opacity-90">View Projects</a>
        <a href="/resume.pdf" class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">Resume</a>
      </div>
      <div class="mt-6 flex gap-4 justify-center sm:justify-start text-sm text-slate-500 dark:text-slate-400">
        <a href="https://github.com/siddhantpathakk" class="hover:text-slate-900 dark:hover:text-white">GitHub</a>
        <a href="https://www.linkedin.com/in/siddhantpathakk" class="hover:text-slate-900 dark:hover:text-white">LinkedIn</a>
        <a href="mailto:siddhantpathak.applications@gmail.com" class="hover:text-slate-900 dark:hover:text-white">Email</a>
      </div>
    </div>
    <div class="shrink-0">
      <div class="h-32 w-32 sm:h-40 sm:w-40 rounded-full bg-gradient-to-br from-slate-200 to-slate-400 dark:from-slate-700 dark:to-slate-900 flex items-center justify-center text-3xl font-bold text-slate-700 dark:text-slate-200">
        SP
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">About</h2>
    <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
      I'm a Data Scientist at Singapore Airlines, where I design and operate the GenAI platform — an LLM gateway
      integrating 30+ frontier and open-source models, production-grade RAG pipelines for B2B travel search, and
      serverless ML infrastructure powering customer-facing recommenders. I graduated from Nanyang Technological
      University with a B.Eng. in Computer Science (Honours, Distinction) with electives in Data Science and AI.
    </p>
    <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
      My research sits at the intersection of graph neural networks, sequential recommendation, and applied AI.
      Outside work, I'm drawn to the messy, useful edges of ML — on-device inference, retrieval systems, and
      anything that pushes models out of notebooks and into production.
    </p>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Skills</h2>
    <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-4">
      {[
        { title: 'Languages', items: ['Python', 'SQL', 'R', 'C++', 'Java', 'Bash'] },
        { title: 'GenAI & LLMs', items: ['LiteLLM', 'vLLM', 'SGLang', 'LangChain', 'LangGraph', 'RAG'] },
        { title: 'ML & DL', items: ['PyTorch', 'TensorFlow', 'Scikit-learn', 'Flower', 'MLX'] },
        { title: 'Cloud & MLOps', items: ['AWS', 'GCP', 'CI/CD', 'Datadog', 'Splunk', 'Prometheus'] },
      ].map((g) => (
        <div class="rounded-lg border border-slate-200 dark:border-slate-800 p-4">
          <h3 class="text-sm font-semibold">{g.title}</h3>
          <ul class="mt-2 text-sm text-slate-600 dark:text-slate-300 space-y-1">
            {g.items.map((i) => <li>{i}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Projects</h2>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {[
        {
          title: 'TAGON — Graph Neural Networks for Sequential Recommendation',
          tags: 'GNN · Temporal Attention · PyTorch',
          summary:
            'Temporal Attention Graph-Optimised Network modelling dynamic user interactions, improving relevance and timeliness by 20% across five real-world datasets and outperforming SOTA baselines in precision, recall, and user satisfaction.',
          href: 'https://github.com/siddhantpathakk',
        },
        {
          title: 'Icarus AI — GenAI Job Recommendation',
          tags: 'LLM · Explainability · Full-Stack',
          summary:
            'Explainable job recommendation platform using candidate CVs and LLMs to deliver personalised career suggestions. Earned Third Place at the NTU Deep Learning Week Hackathon.',
          href: 'https://github.com/siddhantpathakk',
        },
        {
          title: 'Speech Emotion Recognition with Bi-GRU + Attention',
          tags: 'MELD · Multi-modal · Attention',
          summary:
            'Bi-directional GRU with attention mechanisms on the MELD dataset, improving classification accuracy beyond single-utterance baselines for multi-party dialogue and cross-utterance emotional dynamics.',
          href: 'https://github.com/siddhantpathakk',
        },
        {
          title: 'Expected Goals Model — Singapore Football',
          tags: 'Sports Analytics · Ensembles · NN',
          summary:
            'Spatio-temporal xG framework combining KNN, Random Forest, Logistic Regression, and neural networks with ensemble methods. Achieved 99.58% accuracy on a 1M-point English Premier League dataset. NTU President Research Scholar.',
          href: 'https://github.com/siddhantpathakk',
        },
        {
          title: 'Delphi — News Credibility via GCNs',
          tags: 'GCN · Word2Vec · AWS',
          summary:
            'End-to-end misinformation detection pipeline using GCNs over Twitter propagation patterns, achieving 95% accuracy. Awarded "Innovative Use of Natural Language Processing" distinction.',
          href: 'https://github.com/siddhantpathakk',
        },
      ].map((p) => (
        <a href={p.href} class="block rounded-lg border border-slate-200 dark:border-slate-800 p-5 hover:border-slate-400 dark:hover:border-slate-600 transition-colors">
          <h3 class="font-semibold">{p.title}</h3>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{p.tags}</p>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{p.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Experience</h2>
    <ol class="mt-6 space-y-6 border-l border-slate-200 dark:border-slate-800 pl-6">
      {[
        {
          period: 'Aug 2024 — Present',
          role: 'Data Scientist · Singapore Airlines',
          summary:
            'Re-architected the Flight Recommender onto serverless Lambda + in-house fare cache (~90% infra cost reduction, 33% latency improvement). Built a centralised LLM gateway over 30+ models via LiteLLM, production RAG for B2B travel search, and end-to-end open-source LLM deployments across AWS GPU and on-prem Mac Studio clusters.',
        },
        {
          period: 'Jan 2024 — Apr 2024',
          role: 'Data Science & GenAI Engineer (Intern) · Asurion',
          summary:
            'Built ML models for supply-chain optimisation and customer segmentation. Engineered a GPT-4 + LangChain chatbot with real-time retrieval for scalable customer support, measurably reducing churn.',
        },
        {
          period: 'May 2023 — Aug 2023',
          role: 'Software Development Engineer (Intern) · Glance, InMobi',
          summary:
            'Designed a CI/CD pipeline for ML workflows (Scikit-learn, TensorFlow) enabling on-device training and federated learning. Built a PoC federated server using Flower to orchestrate model sync across distributed mobile devices.',
        },
        {
          period: 'Aug 2022 — Dec 2022',
          role: 'Data Analytics Consultant (Apprentice) · MSD',
          summary:
            'Led a team of 4 to build an internal analytics tool for Adverse Event tracking and drug benchmarking. Shipped Power BI dashboards over Python ETL and an AWS Lambda + S3 ingestion pipeline for real-time reporting on high-volume clinical data.',
        },
        {
          period: 'May 2022 — Aug 2022',
          role: 'AI Algorithm Engineer (Intern) · Panasonic R&D Center',
          summary:
            'Built a real-time monitoring system with Flask, Fuzzy Search, PaddleOCR, and Tesseract for robust text extraction in unstructured environments. Optimised the edge inference pipeline to cut latency by 30%.',
        },
      ].map((e) => (
        <li class="relative">
          <span class="absolute -left-[29px] top-1.5 h-3 w-3 rounded-full bg-slate-400 dark:bg-slate-600"></span>
          <p class="text-xs font-medium text-slate-500 dark:text-slate-400">{e.period}</p>
          <p class="font-semibold mt-0.5">{e.role}</p>
          <p class="text-sm text-slate-600 dark:text-slate-300 mt-1">{e.summary}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- AWARDS & CERTIFICATIONS -->
  <section id="recognition" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Awards & Certifications</h2>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-8">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Awards</h3>
        <ul class="mt-4 space-y-4">
          {[
            {
              title: 'NTU President Research Scholar',
              detail: 'Expected Goal Model for Singapore Football.',
            },
            {
              title: 'Third Place — Deep Learning Week Hackathon',
              detail: 'Icarus AI, NTU.',
            },
            {
              title: 'Innovative Use of Natural Language Processing',
              detail: 'Distinction award for the Delphi news credibility project.',
            },
          ].map((a) => (
            <li>
              <p class="font-semibold text-sm">{a.title}</p>
              <p class="text-sm text-slate-600 dark:text-slate-300 mt-0.5">{a.detail}</p>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Certifications</h3>
        <ul class="mt-4 space-y-3">
          {[
            { title: 'Applied Social Network Analysis in Python', issuer: 'University of Michigan' },
            { title: 'The Science of Well-Being', issuer: 'Yale University' },
            { title: 'Moral Foundation of Politics', issuer: 'Yale University' },
            { title: 'Introduction to Climate Change and Health', issuer: 'Yale University' },
            { title: 'Ubiquitous Learning and Instructional Technologies', issuer: 'University of Illinois at Urbana-Champaign' },
          ].map((c) => (
            <li>
              <p class="font-medium text-sm">{c.title}</p>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{c.issuer}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-12 border-t border-slate-200 dark:border-slate-800 text-center">
    <h2 class="text-2xl font-bold tracking-tight">Contact</h2>
    <p class="mt-4 text-slate-600 dark:text-slate-300">
      Want to chat about GenAI infrastructure, recommender systems, or applied ML? Always up for a good conversation.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="mailto:siddhantpathak.applications@gmail.com" class="rounded-md bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:opacity-90">Email me</a>
      <a href="https://github.com/siddhantpathakk" class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">GitHub</a>
      <a href="https://www.linkedin.com/in/siddhantpathakk" class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">LinkedIn</a>
    </div>
  </section>
</Base>
