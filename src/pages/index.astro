---
import Base from '../layouts/Base.astro';
import AvatarFrame from '../components/AvatarFrame.astro';
import { site } from '../data/site';
---

<Base>
  <section class="pt-12 sm:pt-20 pb-10 flex justify-center">
    <AvatarFrame src={site.photos.avatar} initials={site.initials} size="lg" shape="square" />
  </section>

  <section class="pb-12">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tighter leading-[1.1]">
      A passionate Data Scientist building <span class="text-indigo-600 dark:text-indigo-400">GenAI</span> in Singapore
    </h1>

    <div class="mt-8 space-y-5 text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
      <p>
        I'm Siddhant — a Data Scientist at <span class="text-slate-900 dark:text-white font-medium">Singapore Airlines</span>,
        where I design and operate the GenAI platform: an LLM gateway over 30+ frontier and open-source models,
        production RAG pipelines for B2B travel search, and serverless ML infrastructure powering customer-facing
        recommenders.
      </p>
      <p>
        I graduated from <span class="text-slate-900 dark:text-white font-medium">Nanyang Technological University</span>
        with a B.Eng. in Computer Science (Honours, Distinction). My research
        sits at the intersection of graph neural networks, sequential recommendation, and applied AI.
      </p>
      <p>
        Outside work I'm drawn to the messy, useful edges of ML — on-device inference, retrieval systems, and
        anything that pushes models out of notebooks and into production.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href="/projects"
        class="rounded-md bg-indigo-600 dark:bg-indigo-500 text-white px-4 py-2 text-sm font-medium hover:bg-indigo-700 dark:hover:bg-indigo-400"
      >
        View projects
      </a>
      <a
        href="/resume"
        class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900"
      >
        Resume
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
      <a href={site.socials.github} class="hover:text-indigo-600 dark:hover:text-indigo-400">GitHub ↗</a>
      <a href={site.socials.linkedin} class="hover:text-indigo-600 dark:hover:text-indigo-400">LinkedIn ↗</a>
      <a href={site.socials.twitter} class="hover:text-indigo-600 dark:hover:text-indigo-400">Twitter ↗</a>
      <a href={site.socials.email} class="hover:text-indigo-600 dark:hover:text-indigo-400">Email ↗</a>
    </div>
  </section>
</Base>
