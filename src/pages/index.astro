---
import Base from '../layouts/Base.astro';
import AvatarFrame from '../components/AvatarFrame.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Timeline from '../components/Timeline.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import AchievementList from '../components/AchievementList.astro';
import { site } from '../data/site';
import { projects } from '../data/projects';
import { experience } from '../data/experience';
import { skills } from '../data/skills';
import { awards, certifications } from '../data/achievements';
---

<Base>
  <!-- HERO -->
  <section class="pt-20 pb-16 flex flex-col sm:flex-row items-center gap-8">
    <div class="flex-1 text-center sm:text-left">
      <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Hi, I'm</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mt-2">{site.name}</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        Data Scientist at <span class="text-slate-900 dark:text-white font-medium">Singapore Airlines</span> building
        <span class="text-slate-900 dark:text-white font-medium">GenAI infrastructure</span>, LLM gateways, and
        <span class="text-slate-900 dark:text-white font-medium">RAG systems</span>. NTU Computer Science graduate researching
        <span class="text-slate-900 dark:text-white font-medium">graph neural networks</span> for recommender systems.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 justify-center sm:justify-start">
        <a href="#projects" class="rounded-md bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:opacity-90">View Projects</a>
        <a href={site.resumeUrl} class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">Resume</a>
      </div>
      <div class="mt-6 flex gap-4 justify-center sm:justify-start text-sm text-slate-500 dark:text-slate-400">
        <a href={site.socials.github} class="hover:text-slate-900 dark:hover:text-white">GitHub</a>
        <a href={site.socials.linkedin} class="hover:text-slate-900 dark:hover:text-white">LinkedIn</a>
        <a href={site.socials.email} class="hover:text-slate-900 dark:hover:text-white">Email</a>
      </div>
    </div>
    <div class="shrink-0">
      <AvatarFrame initials={site.initials} size="md" shape="circle" />
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">About</h2>
    <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
      I'm a Data Scientist at Singapore Airlines, where I design and operate the GenAI platform — an LLM gateway
      integrating 30+ frontier and open-source models, production-grade RAG pipelines for B2B travel search, and
      serverless ML infrastructure powering customer-facing recommenders. I graduated from Nanyang Technological
      University with a B.Eng. in Computer Science (Honours, Distinction) with electives in Data Science and AI.
    </p>
    <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
      My research sits at the intersection of graph neural networks, sequential recommendation, and applied AI.
      Outside work, I'm drawn to the messy, useful edges of ML — on-device inference, retrieval systems, and
      anything that pushes models out of notebooks and into production.
    </p>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Skills</h2>
    <div class="mt-6">
      <SkillsGrid groups={skills} columns={4} />
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Projects</h2>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Experience</h2>
    <div class="mt-6">
      <Timeline items={experience} variant="work" />
    </div>
  </section>

  <!-- AWARDS & CERTIFICATIONS -->
  <section id="recognition" class="py-12 border-t border-slate-200 dark:border-slate-800">
    <h2 class="text-2xl font-bold tracking-tight">Awards & Certifications</h2>
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-8">
      <AchievementList heading="Awards" items={awards} variant="award" />
      <AchievementList heading="Certifications" items={certifications} variant="certification" />
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-12 border-t border-slate-200 dark:border-slate-800 text-center">
    <h2 class="text-2xl font-bold tracking-tight">Contact</h2>
    <p class="mt-4 text-slate-600 dark:text-slate-300">
      Want to chat about GenAI infrastructure, recommender systems, or applied ML? Always up for a good conversation.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href={site.socials.email} class="rounded-md bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:opacity-90">Email me</a>
      <a href={site.socials.github} class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">GitHub</a>
      <a href={site.socials.linkedin} class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900">LinkedIn</a>
    </div>
  </section>
</Base>
