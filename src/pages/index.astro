---
import Base from '../layouts/Base.astro';
import AvatarFrame from '../components/AvatarFrame.astro';
import { site } from '../data/site';

const headline = 'A passionate Data Scientist building GenAI in Singapore';
const words = headline.split(' ');
---

<Base>
  <!-- HERO -->
  <section class="pt-12 sm:pt-20 pb-10 flex justify-center">
    <div class="avatar-parallax">
      <AvatarFrame src={site.photos.avatar} initials={site.initials} size="lg" shape="square" />
    </div>
  </section>

  <section class="pb-12">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tighter leading-[1.1]">
      {words.map((word, i) => (
        <>
          <span class="word-reveal" style={`--delay: ${80 + i * 70}ms`}>{word}</span>
          {i < words.length - 1 ? ' ' : ''}
        </>
      ))}
    </h1>

    <div class="mt-8 space-y-5 text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
      <p class="fade-in" style={`--delay: ${80 + words.length * 70 + 100}ms`}>
        I'm Siddhant — a Data Scientist at <span class="text-slate-900 dark:text-white font-medium">Singapore Airlines</span>,
        where I design and operate the GenAI platform: an LLM gateway over 30+ frontier and open-source models,
        production RAG pipelines for B2B travel search, and serverless ML infrastructure powering customer-facing
        recommenders.
      </p>
      <p class="reveal">
        I graduated from <span class="text-slate-900 dark:text-white font-medium">Nanyang Technological University</span>
        with a B.Eng. in Computer Science (Honours, Distinction) as an ASEAN Undergraduate Scholar. My research
        sits at the intersection of graph neural networks, sequential recommendation, and applied AI.
      </p>
      <p class="reveal">
        Outside work I'm drawn to the messy, useful edges of ML — on-device inference, retrieval systems, and
        anything that pushes models out of notebooks and into production.
      </p>
    </div>

    <div class="reveal mt-10 flex flex-wrap gap-3">
      <a
        href="/projects"
        class="rounded-md bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:opacity-90 transition-opacity"
      >
        View projects
      </a>
      <a
        href="/resume"
        class="rounded-md border border-slate-300 dark:border-slate-700 px-4 py-2 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900 transition-colors"
      >
        Resume
      </a>
    </div>

    <div class="reveal mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
      <a href={site.socials.github} class="hover:text-slate-900 dark:hover:text-white transition-colors">
        GitHub ↗
      </a>
      <a href={site.socials.linkedin} class="hover:text-slate-900 dark:hover:text-white transition-colors">
        LinkedIn ↗
      </a>
      <a href={site.socials.email} class="hover:text-slate-900 dark:hover:text-white transition-colors">
        Email ↗
      </a>
    </div>
  </section>
</Base>
