---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import AchievementList from '../components/AchievementList.astro';
import { awards, certifications } from '../data/achievements';
---

<Base
  wide
  title="Achievements · Siddhant Pathak"
  description="Awards, scholarships, and certifications."
>
  <PageHeader
    eyebrow="Achievements"
    title="Awards & certifications"
    lede="Recognition picked up along the way — from research scholarships to hackathon distinctions and continued learning."
  />
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 pb-12">
    <AchievementList heading="Awards" items={awards} variant="award" />
    <AchievementList heading="Certifications" items={certifications} variant="certification" />
  </div>
</Base>
