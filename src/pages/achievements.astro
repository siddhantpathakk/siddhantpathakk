---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import AchievementList from '../components/AchievementList.astro';
import { awards } from '../data/achievements';
---

<Base
  wide
  title="Achievements · Siddhant Pathak"
  description="Awards, scholarships, and research recognition."
>
  <PageHeader
    eyebrow="Achievements"
    title="Awards & recognition"
    lede="Research scholarships and hackathon distinctions picked up along the way."
  />
  <div class="max-w-2xl pb-12">
    <AchievementList heading="Awards" items={awards} variant="award" />
  </div>
</Base>
